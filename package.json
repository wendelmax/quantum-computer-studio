{
  "name": "quantum-computer-js",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "./dist-lib/index.umd.js",
  "module": "./dist-lib/index.es.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.es.js",
      "require": "./dist-lib/index.umd.js"
    }
  },
  "description": "Interactive quantum computing simulator with circuit builder, 9 algorithms, oracles, data lab, and API terminal",
  "keywords": [
    "quantum",
    "computing",
    "simulator",
    "circuits",
    "quantum-algorithms",
    "react",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && node scripts/zip-lib.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "@monaco-editor/react": "^4.7.0",
    "i18next": "^25.8.13",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "vite-plugin-dts": "^4.5.4"
  }
}